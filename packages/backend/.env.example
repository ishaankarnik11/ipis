# Database
DATABASE_URL="postgresql://ipis:ipis_dev@localhost:5432/ipis_dev?schema=public"

# JWT
JWT_SECRET="change-me-in-production"

# Server
PORT=3000

# Internal service token (for Puppeteer PDF rendering)
INTERNAL_SERVICE_SECRET="change-me-internal-secret"

# Frontend URL (used by Puppeteer PDF rendering to navigate to dashboards)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
