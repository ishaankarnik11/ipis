{
  "name": "ipis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IPIS — Internal Profitability Intelligence System",
  "scripts": {
    "dev": "pnpm --parallel --filter @ipis/backend --filter @ipis/frontend dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @ipis/shared --filter @ipis/backend --filter @ipis/frontend -r test",
    "test:e2e": "pnpm --filter @ipis/e2e test",
    "build": "pnpm -r build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "typescript-eslint": "^8.24.0",
    "prettier": "^3.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "bcrypt",
      "puppeteer"
    ]
  }
}
